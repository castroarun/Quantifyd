# Backtest data: ignore ALL binary artifacts. Live trading state (SQLite DBs)
# must NEVER be tracked — a `git pull` that touches a tracked DB will
# overwrite live runtime data. 2026-04-24 incident: git reset wiped
# orb_positions table mid-session.
# Large files and any snapshot-worthy artifacts go to GitHub Releases via
# scripts/backup_to_github_release.sh.
backtest_data/*
!backtest_data/.gitkeep

# Static config / result JSONs (backtest artifacts, instrument tokens)
!backtest_data/*.json

# Never commit secrets, even with the allow-lists above
backtest_data/access_token.json

# Runtime state written each time a job fires — daily-changing, never
# meaningful in git history. The validator and pre-market brief publish
# their latest report here so the API endpoints can serve it.
backtest_data/validator_latest_*.json
backtest_data/premarket_brief_latest.json
# NAS pipeline watchdog heartbeat — live per-host runtime state. The VPS
# is canonical; committing the laptop copy would clobber the VPS trail on
# the next `git reset --hard origin/main` deploy (2026-05-18 incident).
backtest_data/nas_watchdog_state.json

# Big data files that must never hit git (use GitHub Releases instead)
backtest_data/market_data.db
backtest_data/options_data.db
backtest_data/*.pkl
backtest_data/fundamentals_cache/


# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files (may be large)
data/*.csv
data/*.parquet
data/*.pkl
data/*.h5
data/fundamentals_cache/
!data/.gitkeep

# Backtest data: ignore everything by default, then un-ignore small files we
# want committed for disaster recovery. Large files go to GitHub Releases via
# scripts/backup_to_github_release.sh.
backtest_data/*
!backtest_data/.gitkeep

# Small trading-state SQLite DBs — safe to commit (~100 KB each, total ~1.5 MB)
!backtest_data/*_trading.db
!backtest_data/backtest_results.db
!backtest_data/mq_agent.db
!backtest_data/tactical_pool.db

# Static config / result JSONs (backtest artifacts, instrument tokens)
!backtest_data/*.json

# Never commit secrets, even with the allow-lists above
backtest_data/access_token.json

# Big data files that must never hit git (use GitHub Releases instead)
backtest_data/market_data.db
backtest_data/options_data.db
backtest_data/*.pkl
backtest_data/fundamentals_cache/

# SQLite journals / WAL files
*.db-journal
*.db-wal
*.db-shm

# Flask session files
flask_session/

# Environment variables
.env
.env.local
.env*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Local settings
.claude/settings.local.json

# Test/Coverage
.coverage
htmlcov/
.pytest_cache/
.tox/

# Logs
*.log
logs/

# Secrets (never commit)
*.pem
*.key
credentials.json
secrets.json

.vercel

# Sweep logs (verbose output)
*_sweep_log.txt
*_log.txt
scc/.next/
scc/node_modules/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Local-only helper scripts (may contain credentials)
scripts/_vps_helper.py

# Scheduled tasks personal state
.claude/scheduled_tasks.lock
scc/tsconfig.tsbuildinfo

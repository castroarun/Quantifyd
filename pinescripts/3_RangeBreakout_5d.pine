//@version=5
indicator("Range Breakout 5D (L+S)", overlay=true, max_labels_count=500, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════
// STRATEGY RULES:
// - 5-day high/low channel from bars [1] to [5]
// - LONG:  FIRST bar CLOSING above 5d high (prev bar closed inside)
// - SHORT: FIRST bar CLOSING below 5d low (prev bar closed inside)
// - SL = opposite channel extreme, TP = 2× risk, MaxHold = 15 bars
// - Only first breakout bar triggers — no repeats while trending
// ═══════════════════════════════════════════════════════════════

tpMult  = input.float(2.0, "TP Multiplier", minval=1.0, step=0.5)
maxHold = input.int(15, "Max Hold (bars)", minval=1)

// 5-day high and low from previous 5 bars (NOT including current bar)
high5d = ta.highest(high[1], 5)
low5d  = ta.lowest(low[1], 5)

// ─── PLOT 5-DAY CHANNEL ───
plot(high5d, title="5D High", color=color.new(color.teal, 30), linewidth=2, style=plot.style_stepline)
plot(low5d, title="5D Low", color=color.new(color.orange, 30), linewidth=2, style=plot.style_stepline)

// ─── FIRST BREAKOUT ONLY (close-based) ───
// Long: close above 5d high, prev bar closed inside channel
longBreak  = close > high5d and close[1] <= high5d[1] and high5d > low5d
// Short: close below 5d low, prev bar closed inside channel
shortBreak = close < low5d and close[1] >= low5d[1] and high5d > low5d

longRisk  = high5d - low5d
longTP    = high5d + tpMult * longRisk
shortRisk = high5d - low5d
shortTP   = low5d - tpMult * shortRisk

// ─── PLOT LONG ENTRIES ───
plotshape(longBreak and longRisk > 0, title="Long Entry", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, text="L")

if longBreak and longRisk > 0
    line.new(bar_index, high5d, bar_index + maxHold, high5d, color=color.blue, style=line.style_solid, width=1)
    line.new(bar_index, low5d, bar_index + maxHold, low5d, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, longTP, bar_index + maxHold, longTP, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index + maxHold, longTP, "TP " + str.tostring(longTP, "#.##"), style=label.style_label_left, color=color.green, textcolor=color.white, size=size.tiny)
    label.new(bar_index + maxHold, low5d, "SL " + str.tostring(low5d, "#.##"), style=label.style_label_left, color=color.red, textcolor=color.white, size=size.tiny)

// ─── PLOT SHORT ENTRIES ───
plotshape(shortBreak and shortRisk > 0, title="Short Entry", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, text="S")

if shortBreak and shortRisk > 0
    line.new(bar_index, low5d, bar_index + maxHold, low5d, color=color.blue, style=line.style_solid, width=1)
    line.new(bar_index, high5d, bar_index + maxHold, high5d, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, shortTP, bar_index + maxHold, shortTP, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index + maxHold, shortTP, "TP " + str.tostring(shortTP, "#.##"), style=label.style_label_left, color=color.green, textcolor=color.white, size=size.tiny)
    label.new(bar_index + maxHold, high5d, "SL " + str.tostring(high5d, "#.##"), style=label.style_label_left, color=color.red, textcolor=color.white, size=size.tiny)

// ─── INFO TABLE ───
var table infoTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70))
if barstate.islast
    table.cell(infoTable, 0, 0, "Range Breakout 5D", text_color=color.yellow, text_size=size.small)
    table.cell(infoTable, 0, 1, "Entry:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 1, "FIRST break of 5d high (L) / low (S)", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 2, "SL:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 2, "Opposite 5d extreme", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 3, "TP:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 3, str.tostring(tpMult) + "x risk", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 4, "MaxHold:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 4, str.tostring(maxHold) + " bars", text_color=color.white, text_size=size.tiny)

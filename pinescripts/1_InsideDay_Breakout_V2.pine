//@version=5
indicator("InsideDay Breakout V2 (Filtered)", overlay=true, max_labels_count=500, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════
// V2 IMPROVEMENTS over V1:
// 1. EMA(20) trend filter — longs only above EMA, shorts only below
// 2. Volume filter — inside day volume must be < prev bar volume (true consolidation)
// 3. TP reduced from 3× to 2× risk (more realistic target)
// 4. Inner bar must be >= 40% of outer bar range (avoid tiny inside bars)
// 5. MaxHold reduced from 5 to 3 bars (cut losers faster)
// ═══════════════════════════════════════════════════════════════

// ─── INPUTS ───
emaLen       = input.int(20,  "Trend EMA Length", minval=5)
tpMult       = input.float(2.0, "TP Multiplier (× risk)", minval=1.0, step=0.5)
slMult       = input.float(2.0, "SL ATR Multiplier", minval=0.5, step=0.5)
maxHold      = input.int(3,   "Max Hold (bars)", minval=1)
minBarRatio  = input.float(0.4, "Min Inner/Outer Bar Ratio", minval=0.1, step=0.1)
useVolFilter = input.bool(true, "Volume Filter (inner < outer)")
useTrend     = input.bool(true, "EMA Trend Filter")

// ─── INDICATORS ───
atr14 = ta.atr(14)
ema   = ta.ema(close, emaLen)

// ─── INSIDE DAY DETECTION ───
outerRange = high[1] - low[1]
innerRange = high - low
barRatio   = outerRange > 0 ? innerRange / outerRange : 0

isInsideDay = high < high[1] and low > low[1] and barRatio >= minBarRatio
volOk       = not useVolFilter or (volume < volume[1])
isQualityID = isInsideDay and volOk

// ─── LONG SETUP ───
// Inside day detected → next bar: buy-stop at outer bar high
longSignal    = isQualityID[1]
longStopLevel = high[2]  // outer bar high
trendLongOk   = not useTrend or (close > ema)
longTriggered = longSignal and trendLongOk and high >= longStopLevel

longEntry = longStopLevel
longATR   = atr14[1]
longSL    = longEntry - slMult * longATR
longRisk  = longEntry - longSL
longTP    = longEntry + tpMult * longRisk

// ─── SHORT SETUP ───
shortSignal    = isQualityID[1]
shortStopLevel = low[2]  // outer bar low
trendShortOk   = not useTrend or (close < ema)
shortTriggered = shortSignal and trendShortOk and low <= shortStopLevel

shortEntry = shortStopLevel
shortATR   = atr14[1]
shortSL    = shortEntry + slMult * shortATR
shortRisk  = shortSL - shortEntry
shortTP    = shortEntry - tpMult * shortRisk

// ─── PLOT EMA ───
plot(useTrend ? ema : na, "EMA", color=color.new(color.orange, 30), linewidth=1)

// ─── PLOT INSIDE DAY (quality only) ───
bgcolor(isQualityID ? color.new(color.yellow, 85) : na, title="Quality Inside Day")

// ─── PLOT REJECTED INSIDE DAYS (failed filters) ───
isRejectedID = isInsideDay and not isQualityID
plotshape(isRejectedID, title="Rejected ID", style=shape.xcross,
     location=location.abovebar, color=color.new(color.gray, 50), size=size.tiny)

// ─── PLOT LONG ENTRIES ───
plotshape(longTriggered, title="Long Entry", style=shape.triangleup,
     location=location.belowbar, color=color.green, size=size.small, text="L")

if longTriggered
    line.new(bar_index, longEntry, bar_index + maxHold, longEntry, color=color.blue, style=line.style_solid, width=1)
    line.new(bar_index, longSL, bar_index + maxHold, longSL, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, longTP, bar_index + maxHold, longTP, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index + maxHold, longTP, "TP " + str.tostring(longTP, "#.##"),
         style=label.style_label_left, color=color.green, textcolor=color.white, size=size.tiny)
    label.new(bar_index + maxHold, longSL, "SL " + str.tostring(longSL, "#.##"),
         style=label.style_label_left, color=color.red, textcolor=color.white, size=size.tiny)

// ─── PLOT SHORT ENTRIES ───
plotshape(shortTriggered, title="Short Entry", style=shape.triangledown,
     location=location.abovebar, color=color.red, size=size.small, text="S")

if shortTriggered
    line.new(bar_index, shortEntry, bar_index + maxHold, shortEntry, color=color.blue, style=line.style_solid, width=1)
    line.new(bar_index, shortSL, bar_index + maxHold, shortSL, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, shortTP, bar_index + maxHold, shortTP, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index + maxHold, shortTP, "TP " + str.tostring(shortTP, "#.##"),
         style=label.style_label_left, color=color.green, textcolor=color.white, size=size.tiny)
    label.new(bar_index + maxHold, shortSL, "SL " + str.tostring(shortSL, "#.##"),
         style=label.style_label_left, color=color.red, textcolor=color.white, size=size.tiny)

// ─── INFO TABLE ───
var table infoTable = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 70))
if barstate.islast
    table.cell(infoTable, 0, 0, "InsideDay V2 (Filtered)", text_color=color.yellow, text_size=size.small)
    table.cell(infoTable, 0, 1, "Entry:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 1, "Buy-stop outer high / Sell-stop outer low", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 2, "SL:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 2, str.tostring(slMult) + "x ATR(14) from entry", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 3, "TP:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 3, str.tostring(tpMult) + "x risk", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 4, "MaxHold:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 4, str.tostring(maxHold) + " bars", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 5, "Trend:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 5, useTrend ? "EMA(" + str.tostring(emaLen) + ") filter ON" : "OFF", text_color=useTrend ? color.green : color.red, text_size=size.tiny)
    table.cell(infoTable, 0, 6, "Volume:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 6, useVolFilter ? "Inner < Outer ON" : "OFF", text_color=useVolFilter ? color.green : color.red, text_size=size.tiny)

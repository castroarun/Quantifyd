//@version=5
indicator("InsideDay Breakout (L+S)", overlay=true, max_labels_count=500, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════
// STRATEGY RULES:
// - Inside Day: today's high < yesterday's high AND today's low > yesterday's low
// - LONG:  Buy-stop at yesterday's high (the outer bar)
//          SL = entry - 2×ATR(14), TP = entry + 3×risk, MaxHold = 5 bars
// - SHORT: Sell-stop at yesterday's low (the outer bar)
//          SL = entry + 2×ATR(14), TP = entry - 3×risk, MaxHold = 5 bars
// - Signal detected at bar close → stop order placed for NEXT bar
// ═══════════════════════════════════════════════════════════════

atr14 = ta.atr(14)

// Detect inside day: current bar is inside previous bar
isInsideDay = high < high[1] and low > low[1]

// ─── LONG SETUP ───
// Inside day detected → next bar: buy-stop at outer bar high (high[1] of inside day = high[2] of entry bar)
longSignal = isInsideDay[1]  // inside day was yesterday
longStopLevel = high[2]      // outer bar high (2 bars ago from entry bar)
longTriggered = longSignal and high >= longStopLevel

longEntry = longStopLevel
longATR = atr14[1]
longSL = longEntry - 2 * longATR
longRisk = longEntry - longSL
longTP = longEntry + 3 * longRisk

// ─── SHORT SETUP ───
shortSignal = isInsideDay[1]
shortStopLevel = low[2]       // outer bar low
shortTriggered = shortSignal and low <= shortStopLevel

shortEntry = shortStopLevel
shortATR = atr14[1]
shortSL = shortEntry + 2 * shortATR
shortRisk = shortSL - shortEntry
shortTP = shortEntry - 3 * shortRisk

// ─── PLOT INSIDE DAY DETECTION ───
bgcolor(isInsideDay ? color.new(color.yellow, 85) : na, title="Inside Day Bar")

// ─── PLOT LONG ENTRIES ───
plotshape(longTriggered, title="Long Entry", style=shape.triangleup,
     location=location.belowbar, color=color.green, size=size.small, text="L")

// Long SL and TP lines (draw for 5 bars = max hold)
if longTriggered
    line.new(bar_index, longEntry, bar_index + 5, longEntry, color=color.blue, style=line.style_solid, width=1)
    line.new(bar_index, longSL, bar_index + 5, longSL, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, longTP, bar_index + 5, longTP, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index + 5, longTP, "TP " + str.tostring(longTP, "#.##"),
         style=label.style_label_left, color=color.green, textcolor=color.white, size=size.tiny)
    label.new(bar_index + 5, longSL, "SL " + str.tostring(longSL, "#.##"),
         style=label.style_label_left, color=color.red, textcolor=color.white, size=size.tiny)

// ─── PLOT SHORT ENTRIES ───
plotshape(shortTriggered, title="Short Entry", style=shape.triangledown,
     location=location.abovebar, color=color.red, size=size.small, text="S")

if shortTriggered
    line.new(bar_index, shortEntry, bar_index + 5, shortEntry, color=color.blue, style=line.style_solid, width=1)
    line.new(bar_index, shortSL, bar_index + 5, shortSL, color=color.red, style=line.style_dashed, width=1)
    line.new(bar_index, shortTP, bar_index + 5, shortTP, color=color.green, style=line.style_dashed, width=1)
    label.new(bar_index + 5, shortTP, "TP " + str.tostring(shortTP, "#.##"),
         style=label.style_label_left, color=color.green, textcolor=color.white, size=size.tiny)
    label.new(bar_index + 5, shortSL, "SL " + str.tostring(shortSL, "#.##"),
         style=label.style_label_left, color=color.red, textcolor=color.white, size=size.tiny)

// ─── INFO TABLE ───
var table infoTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70))
if barstate.islast
    table.cell(infoTable, 0, 0, "InsideDay Breakout", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 0, 1, "Entry:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 1, "Buy-stop outer high / Sell-stop outer low", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 2, "SL:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 2, "2x ATR(14) from entry", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 3, "TP:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 3, "3x risk (RR 3:1)", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 0, 4, "MaxHold:", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 4, "5 bars", text_color=color.white, text_size=size.tiny)

// @version=5
// Breakout V3 PRIMARY System - SuperTrend-Style Trade Setup
// Auto-detects ALPHA, T1B, MOMVOL signals on any NSE daily chart
// Shows full trade lifecycle with SuperTrend-style trailing stop visualization
// System: PRIMARY = ALPHA OR T1B OR MOMVOL (332 trades, 66.9% win, PF 6.44)
//
// STOP LOSS MODES:
//   FIXED:   SL = consolidation low (original system). 67.5% WR, PF 6.38
//   TRAIL:   SL = highest high since entry minus trail%. 20% trail: 61.7% WR, PF 4.96, 0 severe losses
//   RATCHET: SL starts at consol low, ratchets up to max(consol_low, trail_sl)
//
// BREAKOUT GATE: Requires "fresh breakout" — price must have been BELOW consolidation high
// within the last 5 bars before crossing above it. Approximates Darvas Box event detection.
indicator("BV3 PRIMARY", overlay=true, max_labels_count=500, max_lines_count=500)

// ===== SETTINGS =====
i_consol_len      = input.int(60,  "Consolidation Length", minval=20, maxval=200)
i_hold_days       = input.int(125, "Max Holding Period (trading days)", minval=10, maxval=500)
i_bo_lookback     = input.int(5,   "Fresh Breakout Lookback (bars)", minval=2, maxval=20, tooltip="Price must have been below consolidation high within this many bars ago.")
i_sl_mode         = input.string("TRAIL", "Stop Loss Mode", options=["FIXED", "TRAIL", "RATCHET"], tooltip="FIXED=consol low. TRAIL=trails X% below peak. RATCHET=starts at consol low, ratchets up.")
i_trail_pct       = input.float(20.0, "Trail % (below highest high)", minval=5, maxval=50, step=5, tooltip="Only for TRAIL/RATCHET mode. 20% = 0 severe losses. 30% = highest total return.")
i_show_alpha      = input.bool(true, "Show ALPHA signals")
i_show_t1b        = input.bool(true, "Show T1B signals")
i_show_momvol     = input.bool(true, "Show MOMVOL signals")
i_show_sl         = input.bool(true, "Show Stop Loss trail")
i_show_entry_line = input.bool(true, "Show Entry price line")
i_show_labels     = input.bool(true, "Show Entry/Exit labels")

// ===== CORE INDICATORS =====
rsi14 = ta.rsi(close, 14)

ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema20_gt_50 = ema20 > ema50

w_ema20 = request.security(syminfo.tickerid, "W", ta.ema(close, 20))
w_ema50 = request.security(syminfo.tickerid, "W", ta.ema(close, 50))
w_ema20_gt_50 = w_ema20 > w_ema50

vol_sma50 = ta.sma(volume, 50)
volume_ratio = vol_sma50 > 0 ? volume / vol_sma50 : 0

vol_sma10 = ta.sma(volume, 10)
vol_trend = vol_sma50 > 0 ? vol_sma10 / vol_sma50 : 0

ath = ta.highest(high, 500)
ath_proximity = ath > 0 ? close / ath * 100 : 0

consol_high = ta.highest(high, i_consol_len)[1]
breakout_pct = consol_high > 0 ? (close - consol_high) / consol_high * 100 : 0

mom_60d = close[60] > 0 ? (close - close[60]) / close[60] * 100 : 0

williams_r = -100 * (ta.highest(high, 14) - close) / (ta.highest(high, 14) - ta.lowest(low, 14))

// ===== STOP LOSS = Consolidation Low =====
consol_low = ta.lowest(low, i_consol_len)[1]

// ===== FRESH BREAKOUT GATE =====
above_consol = close > consol_high
was_below_recently = false
for i = 1 to i_bo_lookback
    if close[i] <= ta.highest(high, i_consol_len)[i]
        was_below_recently := true
is_fresh_breakout = above_consol and was_below_recently

// ===== STRATEGY FILTERS =====
is_alpha  = is_fresh_breakout and rsi14 >= 75 and volume_ratio >= 3.0 and ema20_gt_50
is_t1b    = is_fresh_breakout and breakout_pct >= 3.0 and vol_trend >= 1.2 and ath_proximity >= 85 and ema20_gt_50 and w_ema20_gt_50 and williams_r >= -20
is_momvol = is_fresh_breakout and mom_60d >= 15.0 and vol_trend >= 1.2 and ath_proximity >= 90 and volume_ratio >= 3.0

is_primary = (i_show_alpha and is_alpha) or (i_show_t1b and is_t1b) or (i_show_momvol and is_momvol)
was_primary = (i_show_alpha and is_alpha[1]) or (i_show_t1b and is_t1b[1]) or (i_show_momvol and is_momvol[1])
is_new_signal = is_primary and not was_primary

// ===== TRADE STATE (persistent across bars) =====
var bool   inTrade      = false
var float  entryPrice   = na
var float  slPrice      = na
var float  fixedSl      = na
var float  highestHigh  = na
var int    entryBar     = na
var string tradeStrat   = ""
var line   entryLine    = na

// ===== TRADE COUNTERS =====
var int total_trades = 0
var int wins         = 0
var int losses       = 0
var float totalPnl   = 0.0

// ===== SIGNAL FLAGS (for plotshape, must be evaluated at top level) =====
var bool entrySignal  = false
var bool exitSignal   = false
var bool exitIsWin    = false
var float exitPnl     = 0.0
var float exitPriceV  = 0.0

// Reset flags each bar
entrySignal := false
exitSignal  := false

// ===== DETERMINE STRATEGY NAME & COLOR =====
strat_txt = is_alpha ? "ALPHA" : is_t1b ? "T1B" : "MOMVOL"

// ===== EXIT CONDITIONS (checked BEFORE entry) =====
sl_hit    = inTrade and low <= slPrice
time_exit = inTrade and (bar_index - entryBar >= i_hold_days)

// ===== PROCESS EXIT =====
if sl_hit or time_exit
    float exitPrice = sl_hit ? slPrice : close
    float pnl = (exitPrice - entryPrice) / entryPrice * 100
    bool isWin = exitPrice >= entryPrice

    total_trades += 1
    totalPnl += pnl
    if isWin
        wins += 1
    else
        losses += 1

    // Set exit signal flags
    exitSignal  := true
    exitIsWin   := isWin
    exitPnl     := pnl
    exitPriceV  := exitPrice

    // Snap entry line to exit bar
    if not na(entryLine) and i_show_entry_line
        line.set_x2(entryLine, bar_index)

    // Exit label with details
    if i_show_labels
        string reason = sl_hit ? "SL HIT" : "EXIT " + str.tostring(i_hold_days) + "d"
        label.new(bar_index, high * 1.01, reason + "\nRs." + str.tostring(exitPrice, "#.0") + "\n" + str.tostring(pnl, "+#.1") + "%", style=label.style_label_down, color=(isWin ? color.green : color.red), textcolor=color.white, size=size.small)

    // Reset state
    inTrade     := false
    entryPrice  := na
    slPrice     := na
    fixedSl     := na
    highestHigh := na
    entryBar    := na
    entryLine   := na

// ===== PROCESS ENTRY =====
if is_new_signal and not inTrade
    inTrade     := true
    entryPrice  := close
    fixedSl     := consol_low
    highestHigh := high
    entryBar    := bar_index
    tradeStrat  := strat_txt
    entrySignal := true

    // Set initial SL based on mode
    if i_sl_mode == "TRAIL"
        slPrice := high * (1 - i_trail_pct / 100)
    else
        slPrice := consol_low

    // Entry label with details
    if i_show_labels
        string slModeTxt = i_sl_mode == "FIXED" ? "" : " [" + i_sl_mode + " " + str.tostring(i_trail_pct, "#") + "%]"
        label.new(bar_index, low * 0.99, strat_txt + " ENTRY" + slModeTxt + "\nRs." + str.tostring(close, "#.0") + "\nSL: Rs." + str.tostring(slPrice, "#.0"), style=label.style_label_up, color=(is_alpha ? color.orange : is_t1b ? color.green : color.blue), textcolor=color.white, size=size.small)

    // Entry price reference line
    if i_show_entry_line
        entryLine := line.new(bar_index, entryPrice, bar_index + 1, entryPrice, color=color.new(color.blue, 40), width=1, style=line.style_dotted)

// ===== UPDATE TRAILING SL WHILE IN TRADE =====
if inTrade
    highestHigh := math.max(highestHigh, high)

    if i_sl_mode == "TRAIL"
        slPrice := highestHigh * (1 - i_trail_pct / 100)
    else if i_sl_mode == "RATCHET"
        slPrice := math.max(fixedSl, highestHigh * (1 - i_trail_pct / 100))

    // Extend entry line
    if not na(entryLine) and i_show_entry_line
        line.set_x2(entryLine, bar_index + 1)

// ======================================================================
// SUPERTREND-STYLE VISUALIZATION (all plot/plotshape at top level)
// ======================================================================

// ----- SL TRAIL LINE (linebr = breaks at na gaps, no diagonal connections) -----
// Value is na when not in trade, so the line disappears between trades
slPlotVal = inTrade and i_show_sl ? slPrice : na
slTrail = plot(slPlotVal, "Stop Loss Trail", color=color.new(#26a69a, 0), style=plot.style_linebr, linewidth=2)

// ----- FILL between candle body and SL trail (subtle green zone like SuperTrend) -----
bodyMiddle = plot((open + close) / 2, "Body Middle", display=display.none)
fill(bodyMiddle, slTrail, color=inTrade ? color.new(#26a69a, 90) : na, fillgaps=false)

// ----- ENTRY TRIANGLES (plotshape - clean visual markers) -----
plotshape(entrySignal and is_alpha, "ALPHA Entry", style=shape.triangleup, location=location.belowbar, color=color.orange, size=size.small)
plotshape(entrySignal and is_t1b and not is_alpha, "T1B Entry", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
plotshape(entrySignal and is_momvol and not is_alpha and not is_t1b, "MOMVOL Entry", style=shape.triangleup, location=location.belowbar, color=color.blue, size=size.small)

// ----- EXIT TRIANGLES -----
plotshape(exitSignal and exitIsWin, "Win Exit", style=shape.triangledown, location=location.abovebar, color=color.green, size=size.small)
plotshape(exitSignal and not exitIsWin, "Loss Exit", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)

// ----- BACKGROUND: subtle green highlight while in trade -----
bgcolor(inTrade ? color.new(color.green, 95) : na)

// ===== INFO TABLE =====
var table t = table.new(position.top_right, 2, 11, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.islast
    winPct = total_trades > 0 ? wins * 100.0 / total_trades : 0
    avgPnl = total_trades > 0 ? totalPnl / total_trades : 0

    table.cell(t, 0, 0, "System",      text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "PRIMARY",     text_color=color.green, text_size=size.small)
    table.cell(t, 0, 1, "SL Mode",     text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, i_sl_mode + (i_sl_mode != "FIXED" ? " " + str.tostring(i_trail_pct, "#") + "%" : ""), text_color=(i_sl_mode == "FIXED" ? color.gray : color.orange), text_size=size.small)
    table.cell(t, 0, 2, "Trades",      text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(total_trades), text_color=color.yellow, text_size=size.small)
    table.cell(t, 0, 3, "Win%",        text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(winPct, "#.1") + "%", text_color=(winPct >= 60 ? color.green : color.red), text_size=size.small)
    table.cell(t, 0, 4, "W / L",       text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(wins) + " / " + str.tostring(losses), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 5, "Avg P&L",     text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(avgPnl, "+#.1") + "%", text_color=(avgPnl >= 0 ? color.green : color.red), text_size=size.small)
    table.cell(t, 0, 6, "BO%",         text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(breakout_pct, "+#.1") + "%", text_color=(breakout_pct >= 3 ? color.green : color.gray), text_size=size.small)
    table.cell(t, 0, 7, "RSI(14)",     text_color=color.white, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(rsi14, "#.0"), text_color=(rsi14 >= 75 ? color.green : color.gray), text_size=size.small)
    table.cell(t, 0, 8, "Vol Ratio",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 8, str.tostring(volume_ratio, "#.1") + "x", text_color=(volume_ratio >= 3 ? color.green : color.gray), text_size=size.small)
    table.cell(t, 0, 9, "ATH%",        text_color=color.white, text_size=size.small)
    table.cell(t, 1, 9, str.tostring(ath_proximity, "#.0") + "%", text_color=(ath_proximity >= 85 ? color.green : color.gray), text_size=size.small)
    table.cell(t, 0, 10, "In Trade",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 10, inTrade ? "YES (" + tradeStrat + ")" : "NO", text_color=(inTrade ? color.green : color.gray), text_size=size.small)
